.container {
  min-height: 100vh;
  background: #f5f6fa;
  padding: 30rpx;
}

/* 未管理员 */
.not-admin {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.lock-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.not-admin-text {
  font-size: 30rpx;
  color: #999;
}

.openid-text {
  margin-top: 40rpx;
  font-size: 24rpx;
  color: #666;
  background: #fff;
  padding: 20rpx 30rpx;
  border-radius: 12rpx;
  word-break: break-all;
  max-width: 90%;
  text-align: center;
}

.openid-hint {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #999;
  max-width: 80%;
  text-align: center;
}

/* 管理员面板 */
.admin-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.admin-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.admin-count {
  font-size: 24rpx;
  color: #999;
}

/* 加载 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx;
  color: #999;
  font-size: 26rpx;
  gap: 12rpx;
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid #ddd;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 0.6s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 用户卡片 */
.user-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.user-info {
  flex: 1;
  min-width: 0;
}

.user-top-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.user-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #f0f0f0;
}

.user-avatar-placeholder {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #e0e0e0;
}

.user-text-info {
  flex: 1;
  min-width: 0;
}

.user-nickname {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-openid {
  display: block;
  font-size: 22rpx;
  color: #666;
  font-family: 'Courier New', monospace;
  word-break: break-all;
  line-height: 1.4;
}

.user-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 8rpx;
}

.meta-item {
  font-size: 22rpx;
  color: #999;
}

.vip-badge {
  font-size: 20rpx;
  color: #f39c12;
  background: rgba(243, 156, 18, 0.15);
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  font-weight: 600;
}

/* 操作按钮 */
.user-actions {
  flex-shrink: 0;
  margin-left: 16rpx;
}

.action-btn {
  font-size: 22rpx;
  padding: 0 20rpx;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 8rpx;
  border: none;
}

.add-vip-btn {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
}

.remove-vip-btn {
  background: #fff;
  color: #e74c3c;
  border: 2rpx solid #e74c3c;
}

.action-btn::after {
  border: none;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx;
  color: #ccc;
  font-size: 28rpx;
}