<!--pages/barcode/barcode.wxml-->
<view class="page-container">
  <!-- 标题 -->
  <view class="header">
    <text class="title">条码生成工具</text>
  </view>

  <!-- 码类型选择 -->
  <view class="type-selector">
    <view class="type-tabs">
      <view class="type-tab {{codeType === 'qrcode' ? 'active' : ''}}" bindtap="switchType" data-type="qrcode">
        <text>二维码</text>
      </view>
      <view class="type-tab {{codeType === 'barcode' ? 'active' : ''}}" bindtap="switchType" data-type="barcode">
        <text>条形码</text>
      </view>
    </view>
  </view>

  <!-- 输入区域 -->
  <view class="input-section">
    <view class="input-label">
      <text>输入内容</text>
      <text class="input-hint">{{codeType === 'barcode' ? '（仅支持英文数字符号）' : ''}}</text>
    </view>
    <textarea
      class="content-input"
      placeholder="{{codeType === 'qrcode' ? '请输入文本或网址' : '请输入英文/数字/符号'}}"
      value="{{inputText}}"
      bindinput="onInput"
      maxlength="{{codeType === 'barcode' ? 40 : 300}}"
      auto-height
    />
    <view class="char-count">
      <text>{{inputText.length}}/{{codeType === 'barcode' ? 40 : 300}}</text>
    </view>
  </view>

  <!-- 生成按钮 -->
  <view class="btn-generate" bindtap="generateCode">
    <text>生成{{codeType === 'qrcode' ? '二维码' : '条形码'}}</text>
  </view>

  <!-- 预览区域 -->
  <view class="preview-section" wx:if="{{codeImage}}">
    <view class="preview-card">
      <image class="preview-image" src="{{codeImage}}" mode="widthFix" />
    </view>
    <view class="action-buttons">
      <view class="btn-action btn-save" bindtap="saveImage">
        <text>保存到相册</text>
      </view>
      <view class="btn-action btn-copy" bindtap="copyText">
        <text>复制内容</text>
      </view>
    </view>
  </view>

  <!-- 二维码 Canvas (type=2d) -->
  <canvas type="2d" id="qrcodeCanvas" class="hidden-canvas" style="width: 260px; height: 260px;"></canvas>

  <!-- 条形码 Canvas (旧版) -->
  <canvas canvas-id="barcodeCanvas" class="hidden-canvas" style="width: 680rpx; height: 200rpx;"></canvas>

  <!-- 错误提示 -->
  <view class="error-toast" wx:if="{{errorMsg}}">
    <text>{{errorMsg}}</text>
  </view>

  <!-- 生成历史 -->
  <view class="gen-history" wx:if="{{genHistory.length > 0}}">
    <view class="gen-history-header">
      <text class="gen-history-title">生成历史</text>
      <text class="gen-history-clear" bindtap="clearGenHistory">清空</text>
    </view>
    <view class="gen-history-list">
      <view class="gen-history-item" wx:for="{{genHistory}}" wx:key="time" bindtap="onHistoryItemTap" data-item="{{item}}">
        <view class="gen-history-left">
          <text class="gen-history-type {{item.type}}">{{item.typeLabel}}</text>
          <text class="gen-history-text">{{item.text}}</text>
        </view>
        <text class="gen-history-time">{{item.time}}</text>
      </view>
    </view>
  </view>
</view>
