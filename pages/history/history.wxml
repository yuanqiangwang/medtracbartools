<scroll-view scroll-y class="container">
  <!-- 顶部选项卡：扫码 / 生成码 -->
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 'scan' ? 'tab-active' : ''}}" bindtap="switchTab" data-tab="scan">
      <image class="tab-icon" src="/images/icon-scan.svg" mode="aspectFit" />
      <text>扫码</text>
    </view>
    <view class="tab-item {{activeTab === 'generate' ? 'tab-active' : ''}}" bindtap="switchTab" data-tab="generate">
      <image class="tab-icon" src="/images/icon-qr.svg" mode="aspectFit" />
      <text>生成码</text>
    </view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar">
    <image class="search-icon" src="/images/icon-scan.svg" mode="aspectFit" />
    <input class="search-input" placeholder="搜索记录..." value="{{searchText}}" bindinput="onSearch" confirm-type="search" />
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{filteredHistory.length === 0}}">
    <view class="empty-icon-wrap">
      <image class="empty-icon" src="/images/icon-{{activeTab === 'scan' ? 'scan' : 'qr'}}.svg" mode="aspectFit" />
    </view>
    <text class="empty-text">{{searchText ? '未找到匹配记录' : '暂无' + (activeTab === 'scan' ? '扫码' : '生成码') + '记录'}}</text>
  </view>

  <!-- 历史列表 - 按日期分组 -->
  <view class="history-list" wx:if="{{filteredHistory.length > 0}}">
    <block wx:for="{{groupedHistory}}" wx:key="date">
      <view class="date-group">
        <text class="date-label">{{item.date}}</text>
        <view class="date-items">
          <view class="history-item" wx:for="{{item.items}}" wx:for-item="record" wx:key="id" bindtap="onItemTap" data-id="{{record.id}}">
            <!-- 缩略图（仅生成码记录） -->
            <view class="item-thumb" wx:if="{{record.source === 'generate'}}" catchtap="onThumbTap" data-id="{{record.id}}" data-image="{{record.imagePath}}">
              <image class="thumb-img {{record.type === 'barcode' ? 'thumb-bar' : ''}}" src="{{record.imagePath}}" mode="aspectFit" wx:if="{{record.imagePath}}" />
              <view class="thumb-placeholder" wx:else>
                <image class="thumb-placeholder-icon" src="/images/icon-{{record.type}}.svg" mode="aspectFit" />
              </view>
            </view>
            <!-- 扫码图标（仅扫码记录） -->
            <view class="item-scan-icon" wx:if="{{record.source === 'scan'}}">
              <image class="scan-type-img" src="/images/icon-scan.svg" mode="aspectFit" />
            </view>
            <!-- 内容 -->
            <view class="item-content">
              <!-- GS1 记录：显示字段摘要 -->
              <block wx:if="{{record.isGS1 && record.gs1}}">
                <view class="item-gs1-summary">
                  <view class="gs1-field" wx:if="{{record.gs1.gtin}}">
                    <text class="gs1-field-label">GTIN</text>
                    <text class="gs1-field-value">{{record.gs1.gtin}}</text>
                  </view>
                  <view class="gs1-field" wx:if="{{record.gs1.lot}}">
                    <text class="gs1-field-label">LOT</text>
                    <text class="gs1-field-value">{{record.gs1.lot}}</text>
                  </view>
                  <view class="gs1-field" wx:if="{{record.gs1.expirationDate}}">
                    <text class="gs1-field-label">EXP</text>
                    <text class="gs1-field-value">{{record.gs1.expirationDate}}</text>
                  </view>
                  <view class="gs1-field" wx:if="{{!record.gs1.gtin && !record.gs1.lot && !record.gs1.expirationDate}}">
                    <text class="gs1-field-value raw">{{record.text}}</text>
                  </view>
                </view>
              </block>
              <!-- 普通记录：显示原始文本 -->
              <block wx:else>
                <text class="item-text">{{record.text}}</text>
              </block>
              <view class="item-meta">
                <text class="item-type-badge {{record.type}}">{{record.typeLabel}}</text>
                <text class="item-gs1-badge" wx:if="{{record.isGS1}}">GS1</text>
                <text class="item-time">{{record.time}}</text>
              </view>
            </view>
            <!-- 操作 -->
            <view class="item-actions">
              <view class="action-icon" catchtap="onCopyItem" data-text="{{record.text}}">
                <image class="action-img" src="/images/icon-copy.svg" mode="aspectFit" />
              </view>
              <view class="action-icon" catchtap="onDeleteItem" data-id="{{record.id}}">
                <image class="action-img" src="/images/icon-delete.svg" mode="aspectFit" />
              </view>
            </view>
          </view>
        </view>
      </view>
    </block>
  </view>

  <!-- 图片放大预览 -->
  <view class="image-overlay" wx:if="{{previewImage}}" bindtap="closePreview" catchtouchmove="true">
    <image class="preview-fullscreen" src="{{previewImage}}" mode="widthFix" show-menu-by-longpress="{{true}}" catchtap="" />
    <view class="preview-overlay-actions" catchtap="">
      <view class="act-btn act-primary" catchtap="savePreviewImage">保存图片</view>
      <view class="act-btn act-ghost" catchtap="closePreview">关闭</view>
    </view>
    <view class="preview-hint">长按图片保存/分享</view>
  </view>

  <!-- GS1 结构化详情弹窗 -->
  <view class="gs1-detail-mask" wx:if="{{showDetail && detailItem}}" bindtap="closeDetail">
    <view class="gs1-detail-card" catchtap="">
      <!-- 头部 -->
      <view class="gs1-detail-header">
        <text class="gs1-detail-title">GS1 追溯数据</text>
        <text class="gs1-detail-close" bindtap="closeDetail">✕</text>
      </view>

      <!-- 结构化字段 -->
      <view class="gs1-detail-body">
        <block wx:for="{{detailItem.gs1.fields}}" wx:key="ai">
          <view class="gs1-detail-row">
            <view class="gs1-detail-left">
              <text class="gs1-detail-ai">AI {{item.ai}}</text>
              <text class="gs1-detail-label">{{item.label}}</text>
            </view>
            <text class="gs1-detail-value" selectable="true">{{item.value}}</text>
          </view>
        </block>
      </view>

      <!-- 原始数据 -->
      <view class="gs1-detail-raw">
        <view class="gs1-detail-raw-header">
          <text class="gs1-detail-raw-label">原始数据</text>
          <text class="gs1-detail-raw-copy" bindtap="copyRawData">复制</text>
        </view>
        <view class="gs1-detail-raw-box">
          <text class="gs1-detail-raw-text" selectable="true">{{detailItem.text}}</text>
        </view>
      </view>

      <!-- 底部信息 -->
      <view class="gs1-detail-footer">
        <text class="gs1-detail-source">{{detailItem.sourceLabel}} · {{detailItem.typeLabel}} · {{detailItem.time}}</text>
      </view>
    </view>
  </view>

  <!-- 底部操作 -->
  <view class="bottom-actions" wx:if="{{filteredHistory.length > 0}}">
    <view class="btn-clear" bindtap="clearAll">
      <text>清空所有记录</text>
    </view>
  </view>
</scroll-view>
