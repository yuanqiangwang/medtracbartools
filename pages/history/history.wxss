/* ===== 历史记录页面 ===== */
.container {
  background: #F7F8FA;
  min-height: 100vh;
  padding: 0 16px;
}

/* ===== 顶部选项卡 ===== */
.tab-bar {
  display: flex;
  background: #F7F8FA;
  border-radius: 12px;
  padding: 3px;
  margin-top: 16px;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
  height: 44px;
  font-size: 14px;
  font-weight: 500;
  color: #666;
  border-radius: 10px;
  transition: all 0.2s;
}

.tab-item.tab-active {
  background: #5B6CFF;
  color: #fff;
  font-weight: 600;
  box-shadow: 0 2px 8px rgba(91,108,255,0.3);
}

.tab-icon {
  width: 16px;
  height: 16px;
}

.tab-active .tab-icon {
  filter: brightness(0) invert(1);
}

/* ===== 搜索栏 ===== */
.search-bar {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 16px;
  background: #fff;
  border-radius: 12px;
  padding: 0 12px;
  height: 44px;
}

.search-icon {
  width: 18px;
  height: 18px;
  flex-shrink: 0;
  opacity: 0.4;
}

.search-input {
  flex: 1;
  height: 44px;
  font-size: 14px;
  color: #111;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80px 0;
}

.empty-icon-wrap {
  width: 64px;
  height: 64px;
  border-radius: 20px;
  background: rgba(91,108,255,0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16px;
}

.empty-icon {
  width: 32px;
  height: 32px;
}

.empty-text {
  font-size: 14px;
  color: #999;
}

/* ===== 日期分组 ===== */
.date-group {
  margin-top: 24px;
}

.date-label {
  font-size: 13px;
  font-weight: 600;
  color: #999;
  display: block;
  margin-bottom: 8px;
}

.date-items {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

/* ===== 历史项 ===== */
.history-item {
  display: flex;
  align-items: center;
  gap: 12px;
  background: #fff;
  border-radius: 12px;
  padding: 12px;
}

.item-thumb {
  width: 48px;
  height: 48px;
  border-radius: 8px;
  background: #F7F8FA;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.item-scan-icon {
  width: 48px;
  height: 48px;
  border-radius: 8px;
  background: rgba(52,199,89,0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.scan-type-img {
  width: 22px;
  height: 22px;
}

.thumb-img {
  width: 48px;
  height: 48px;
}

.thumb-img.thumb-bar {
  width: 56px;
  height: 32px;
}

.thumb-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.thumb-placeholder-icon {
  width: 20px;
  height: 20px;
  opacity: 0.4;
}

.item-content {
  flex: 1;
  min-width: 0;
}

.item-text {
  font-size: 14px;
  color: #111;
  font-weight: 500;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-meta {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 4px;
}

.item-type-badge {
  font-size: 11px;
  padding: 1px 6px;
  border-radius: 4px;
  font-weight: 500;
}

.item-type-badge.barcode {
  background: rgba(91,108,255,0.08);
  color: #5B6CFF;
}

.item-type-badge.qrcode {
  background: rgba(52,199,89,0.08);
  color: #34C759;
}

.item-gs1-badge {
  font-size: 11px;
  padding: 1px 6px;
  border-radius: 4px;
  font-weight: 500;
  background: rgba(255,153,0,0.1);
  color: #FF9900;
}

.item-text-wrap {
  display: inline;
  word-break: break-all;
}

.item-gs-inline {
  font-size: 10px;
  color: #FF9900;
  background: rgba(255,153,0,0.12);
  padding: 1px 4px;
  border-radius: 3px;
  margin: 0 1px;
}

.item-time {
  font-size: 12px;
  color: #999;
}

.item-actions {
  display: flex;
  gap: 8px;
  flex-shrink: 0;
}

.action-icon {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8px;
}

.action-icon:active {
  background: #F7F8FA;
}

.action-img {
  width: 18px;
  height: 18px;
}

/* ===== Action Buttons (preview overlay) ===== */
.act-btn {
  padding: 8px 20px;
  border-radius: 10px;
  font-size: 13px;
  font-weight: 500;
}

.act-primary {
  background: #5B6CFF;
  color: #fff;
}

.act-ghost {
  background: rgba(255,255,255,0.12);
  color: rgba(255,255,255,0.7);
}

.act-btn:active {
  opacity: 0.85;
}

/* ===== 图片放大预览 ===== */
.image-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.9);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.preview-fullscreen {
  width: 80vw;
  border-radius: 8px;
}

.preview-overlay-actions {
  display: flex;
  gap: 12px;
  margin-top: 24px;
}

.preview-hint {
  color: rgba(255,255,255,0.35);
  font-size: 11px;
  margin-top: 16px;
}

/* ===== 底部操作 ===== */
.bottom-actions {
  padding: 24px 0 48px;
  display: flex;
  justify-content: center;
}

.btn-clear {
  font-size: 14px;
  color: #999;
  padding: 8px 24px;
}

.btn-clear:active {
  color: #5B6CFF;
}

/* ===== GS1 卡片摘要 ===== */
.item-gs1-summary {
  display: flex;
  flex-wrap: wrap;
  gap: 2px 8px;
}

.gs1-field {
  display: flex;
  align-items: baseline;
  gap: 4px;
  line-height: 1.4;
}

.gs1-field-label {
  font-size: 10px;
  font-weight: 700;
  color: #FF9900;
  letter-spacing: 0.5px;
  font-family: 'SF Mono', 'Courier New', monospace;
  flex-shrink: 0;
}

.gs1-field-value {
  font-size: 13px;
  font-weight: 600;
  color: #111;
  font-family: 'SF Mono', 'Courier New', monospace;
}

.gs1-field-value.raw {
  font-size: 12px;
  font-weight: 400;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-family: inherit;
}

/* ===== GS1 详情弹窗 ===== */
.gs1-detail-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 2000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.gs1-detail-card {
  width: 100%;
  max-height: 75vh;
  background: #1a1f2b;
  border-radius: 20px 20px 0 0;
  padding: 0 0 calc(24px + env(safe-area-inset-bottom)) 0;
  display: flex;
  flex-direction: column;
  animation: gs1SlideUp 0.25s ease-out;
}

@keyframes gs1SlideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

/* 详情头部 */
.gs1-detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px 20px 14px;
  border-bottom: 1px solid rgba(255,255,255,0.06);
  flex-shrink: 0;
}

.gs1-detail-title {
  font-size: 16px;
  font-weight: 700;
  color: #ffffff;
}

.gs1-detail-close {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
  color: rgba(255,255,255,0.5);
  font-size: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.gs1-detail-close:active {
  background: rgba(255,255,255,0.15);
}

/* 详情字段列表 */
.gs1-detail-body {
  flex: 1;
  overflow-y: auto;
  padding: 8px 0;
}

.gs1-detail-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 12px 20px;
  border-bottom: 1px solid rgba(255,255,255,0.04);
}

.gs1-detail-left {
  display: flex;
  flex-direction: column;
  gap: 2px;
  flex-shrink: 0;
  margin-right: 16px;
}

.gs1-detail-ai {
  font-size: 13px;
  font-weight: 700;
  color: #FF9900;
  font-family: 'SF Mono', 'Courier New', monospace;
  letter-spacing: 0.5px;
}

.gs1-detail-label {
  font-size: 10px;
  color: rgba(255,255,255,0.35);
  letter-spacing: 0.5px;
  text-transform: uppercase;
}

.gs1-detail-value {
  font-size: 14px;
  font-weight: 600;
  color: rgba(255,255,255,0.9);
  font-family: 'SF Mono', 'Courier New', monospace;
  text-align: right;
  word-break: break-all;
  line-height: 1.5;
}

/* 原始数据区 */
.gs1-detail-raw {
  margin: 8px 20px 0;
  flex-shrink: 0;
}

.gs1-detail-raw-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.gs1-detail-raw-label {
  font-size: 12px;
  font-weight: 600;
  color: rgba(255,255,255,0.35);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.gs1-detail-raw-copy {
  font-size: 13px;
  color: #5B6CFF;
  font-weight: 600;
}

.gs1-detail-raw-copy:active {
  opacity: 0.7;
}

.gs1-detail-raw-box {
  background: rgba(255,255,255,0.04);
  border-radius: 8px;
  padding: 12px;
  border: 1px solid rgba(255,255,255,0.06);
}

.gs1-detail-raw-text {
  font-size: 12px;
  color: rgba(255,255,255,0.5);
  font-family: 'SF Mono', 'Courier New', monospace;
  word-break: break-all;
  line-height: 1.7;
}

/* 底部来源信息 */
.gs1-detail-footer {
  padding: 12px 20px 0;
  flex-shrink: 0;
}

.gs1-detail-source {
  font-size: 12px;
  color: rgba(255,255,255,0.2);
}
