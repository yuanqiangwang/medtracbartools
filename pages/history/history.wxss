/* ===== 历史记录页面 ===== */
.container {
  background: #F7F8FA;
  min-height: 100vh;
  padding: 0 16px;
}

/* ===== 顶部选项卡 ===== */
.tab-bar {
  display: flex;
  background: #F7F8FA;
  border-radius: 12px;
  padding: 3px;
  margin-top: 16px;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
  height: 44px;
  font-size: 14px;
  font-weight: 500;
  color: #666;
  border-radius: 10px;
  transition: all 0.2s;
}

.tab-item.tab-active {
  background: #5B6CFF;
  color: #fff;
  font-weight: 600;
  box-shadow: 0 2px 8px rgba(91,108,255,0.3);
}

.tab-icon {
  width: 16px;
  height: 16px;
}

.tab-active .tab-icon {
  filter: brightness(0) invert(1);
}

/* ===== 搜索栏 ===== */
.search-bar {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 16px;
  background: #fff;
  border-radius: 12px;
  padding: 0 12px;
  height: 44px;
}

.search-icon {
  width: 18px;
  height: 18px;
  flex-shrink: 0;
  opacity: 0.4;
}

.search-input {
  flex: 1;
  height: 44px;
  font-size: 14px;
  color: #111;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80px 0;
}

.empty-icon-wrap {
  width: 64px;
  height: 64px;
  border-radius: 20px;
  background: rgba(91,108,255,0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16px;
}

.empty-icon {
  width: 32px;
  height: 32px;
}

.empty-text {
  font-size: 14px;
  color: #999;
}

/* ===== 日期分组 ===== */
.date-group {
  margin-top: 24px;
}

.date-label {
  font-size: 13px;
  font-weight: 600;
  color: #999;
  display: block;
  margin-bottom: 8px;
}

.date-items {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

/* ===== 历史项 ===== */
.history-item {
  display: flex;
  align-items: center;
  gap: 12px;
  background: #fff;
  border-radius: 12px;
  padding: 12px;
}

.item-thumb {
  width: 48px;
  height: 48px;
  border-radius: 8px;
  background: #F7F8FA;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.item-scan-icon {
  width: 48px;
  height: 48px;
  border-radius: 8px;
  background: rgba(52,199,89,0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.scan-type-img {
  width: 22px;
  height: 22px;
}

.thumb-img {
  width: 48px;
  height: 48px;
}

.thumb-img.thumb-bar {
  width: 56px;
  height: 32px;
}

.thumb-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.thumb-placeholder-icon {
  width: 20px;
  height: 20px;
  opacity: 0.4;
}

.item-content {
  flex: 1;
  min-width: 0;
}

.item-text {
  font-size: 14px;
  color: #111;
  font-weight: 500;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-meta {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 4px;
}

.item-type-badge {
  font-size: 11px;
  padding: 1px 6px;
  border-radius: 4px;
  font-weight: 500;
}

.item-type-badge.barcode {
  background: rgba(91,108,255,0.08);
  color: #5B6CFF;
}

.item-type-badge.qrcode {
  background: rgba(52,199,89,0.08);
  color: #34C759;
}

.item-gs1-badge {
  font-size: 11px;
  padding: 1px 6px;
  border-radius: 4px;
  font-weight: 500;
  background: rgba(255,153,0,0.1);
  color: #FF9900;
}

.item-text-wrap {
  display: inline;
  word-break: break-all;
}

.item-gs-inline {
  font-size: 10px;
  color: #FF9900;
  background: rgba(255,153,0,0.12);
  padding: 1px 4px;
  border-radius: 3px;
  margin: 0 1px;
}

.item-time {
  font-size: 12px;
  color: #999;
}

.item-actions {
  display: flex;
  gap: 8px;
  flex-shrink: 0;
}

.action-icon {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8px;
}

.action-icon:active {
  background: #F7F8FA;
}

.action-img {
  width: 18px;
  height: 18px;
}

/* ===== Action Buttons (preview overlay) ===== */
.act-btn {
  padding: 8px 20px;
  border-radius: 10px;
  font-size: 13px;
  font-weight: 500;
}

.act-primary {
  background: #5B6CFF;
  color: #fff;
}

.act-ghost {
  background: rgba(255,255,255,0.12);
  color: rgba(255,255,255,0.7);
}

.act-btn:active {
  opacity: 0.85;
}

/* ===== 图片放大预览 ===== */
.image-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.9);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.preview-fullscreen {
  width: 80vw;
  border-radius: 8px;
}

.preview-overlay-actions {
  display: flex;
  gap: 12px;
  margin-top: 24px;
}

.preview-hint {
  color: rgba(255,255,255,0.35);
  font-size: 11px;
  margin-top: 16px;
}

/* ===== 底部操作 ===== */
.bottom-actions {
  padding: 24px 0 48px;
  display: flex;
  justify-content: center;
}

.btn-clear {
  font-size: 14px;
  color: #999;
  padding: 8px 24px;
}

.btn-clear:active {
  color: #5B6CFF;
}
