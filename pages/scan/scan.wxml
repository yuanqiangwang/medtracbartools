<view class="container">
  <!-- 顶部标题 -->
  <view class="header">
    <text class="title">扫码识别</text>
    <text class="subtitle">支持条形码和二维码</text>
  </view>

  <!-- 扫码按钮 -->
  <view class="scan-area" wx:if="{{!result}}">
    <view class="scan-icon-wrap" bindtap="startScan">
      <image class="scan-icon" src="/images/scan-icon.png" mode="aspectFit" wx:if="{{false}}"></image>
      <view class="scan-icon-fallback">
        <text class="icon-text">📷</text>
      </view>
    </view>
    <text class="scan-btn-text" bindtap="startScan">点击扫码</text>
    <text class="scan-hint">将条码/二维码放入框内即可自动识别</text>
  </view>

  <!-- 扫码结果 -->
  <view class="result-area" wx:if="{{result}}">
    <view class="result-card">
      <view class="result-header">
        <text class="result-type">{{resultType}}</text>
        <text class="result-format">{{resultFormat}}</text>
      </view>

      <view class="result-content">
        <text class="result-label">识别内容</text>
        <text class="result-value" selectable="{{true}}">{{result}}</text>
      </view>

      <!-- 如果是网址，显示跳转按钮 -->
      <view class="result-actions" wx:if="{{isUrl}}">
        <button class="action-btn url-btn" bindtap="openUrl">打开链接</button>
      </view>

      <view class="result-actions">
        <button class="action-btn copy-btn" bindtap="copyResult">复制内容</button>
        <button class="action-btn gen-btn" bindtap="generateFromResult">生成码图</button>
      </view>
    </view>

    <!-- 扫码历史 -->
    <view class="history-section" wx:if="{{history.length > 0}}">
      <view class="section-header">
        <text class="section-title">扫码历史</text>
        <text class="clear-btn" bindtap="clearHistory">清空</text>
      </view>
      <view class="history-list">
        <view class="history-item" wx:for="{{history}}" wx:key="time" bindtap="showHistoryItem" data-item="{{item}}">
          <view class="history-left">
            <text class="history-type">{{item.type}}</text>
            <text class="history-value">{{item.value}}</text>
          </view>
          <text class="history-time">{{item.time}}</text>
        </view>
      </view>
    </view>

    <!-- 继续扫码 -->
    <button class="scan-again-btn" bindtap="startScan">再次扫码</button>
  </view>
</view>
