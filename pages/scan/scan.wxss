.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 24rpx 32rpx 40rpx;
  box-sizing: border-box;
  max-width: 100vw;
  overflow-x: hidden;
}

/* 顶部 */
.header {
  text-align: center;
  margin-bottom: 40rpx;
  padding-top: 20rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 扫码区域 */
.scan-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.scan-icon-wrap {
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 36rpx;
  border: 4rpx dashed rgba(255, 255, 255, 0.5);
}

.scan-icon-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-text {
  font-size: 72rpx;
}

.scan-btn-text {
  font-size: 34rpx;
  color: #fff;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.scan-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 结果区域 */
.result-area {
  width: 100%;
  box-sizing: border-box;
}

.result-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.1);
  width: 100%;
  box-sizing: border-box;
}

.result-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  gap: 12rpx;
  flex-wrap: wrap;
}

.result-type {
  font-size: 24rpx;
  background: #667eea;
  color: #fff;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
}

.result-format {
  font-size: 22rpx;
  color: #999;
}

.result-content {
  background: #f7f8fa;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}

.result-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.result-value {
  display: block;
  font-size: 28rpx;
  color: #333;
  word-break: break-all;
  line-height: 1.6;
}

.result-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.action-btn {
  flex: 1;
  font-size: 26rpx;
  border-radius: 16rpx;
  padding: 0;
  height: 76rpx;
  line-height: 76rpx;
  min-width: 0;
}

.url-btn {
  background: #667eea;
  color: #fff;
  width: 100% !important;
  flex: none;
  margin-bottom: 8rpx;
}

.copy-btn {
  background: #f0f2f5;
  color: #333;
}

.gen-btn {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
}

/* 历史记录 */
.history-section {
  margin-top: 24rpx;
  width: 100%;
  box-sizing: border-box;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}

.clear-btn {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.history-list {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  overflow: hidden;
  width: 100%;
  box-sizing: border-box;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
  width: 100%;
  box-sizing: border-box;
}

.history-item:last-child {
  border-bottom: none;
}

.history-left {
  flex: 1;
  overflow: hidden;
  margin-right: 16rpx;
  min-width: 0;
}

.history-type {
  display: inline-block;
  font-size: 20rpx;
  background: rgba(255, 255, 255, 0.3);
  color: #fff;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  margin-bottom: 4rpx;
}

.history-value {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.history-time {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
  flex-shrink: 0;
}

/* 再次扫码 */
.scan-again-btn {
  margin-top: 32rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  border: 2rpx solid rgba(255, 255, 255, 0.4);
  border-radius: 16rpx;
  font-size: 28rpx;
  height: 84rpx;
  line-height: 84rpx;
}
