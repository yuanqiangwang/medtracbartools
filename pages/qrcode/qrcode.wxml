<scroll-view scroll-y class="page-container">
  <!-- 输入区域 -->
  <view class="card input-card">
    <view class="card-label">
      <text>输入内容</text>
    </view>
    <textarea
      class="content-input"
      placeholder="请输入文本或网址"
      value="{{inputText}}"
      bindinput="onInput"
      maxlength="300"
      auto-height
    />
    <view class="char-count">
      <text>{{inputText.length}}/300</text>
    </view>
  </view>

  <!-- 预览区域（移到顶部，生成后立即可见） -->
  <view class="preview-section" wx:if="{{codeImage}}">
    <view class="preview-card">
      <image class="preview-image" src="{{codeImage}}" mode="widthFix" show-menu-by-longpress="{{true}}" />
      <view class="preview-text" wx:if="{{showText}}">
        <text>{{inputText}}</text>
      </view>
      <view class="preview-tip">长按图片可保存或分享</view>
    </view>
    <view class="action-buttons">
      <view class="btn-action btn-save" bindtap="saveImage">
        <text>保存到相册</text>
      </view>
      <view class="btn-action btn-share" bindtap="shareImage">
        <text>分享给好友</text>
      </view>
      <view class="btn-action btn-copy" bindtap="copyText">
        <text>复制内容</text>
      </view>
    </view>
  </view>

  <!-- 配置区域 -->
  <view class="card config-card">
    <view class="card-label">
      <text>生成配置</text>
    </view>

    <!-- 显示文本 -->
    <view class="config-row switch-row">
      <text class="config-label">显示文本内容</text>
      <switch checked="{{showText}}" bindchange="toggleShowText" color="#667eea" />
    </view>
  </view>

  <!-- 生成按钮 -->
  <view class="btn-generate" bindtap="generateCode">
    <text>生成二维码</text>
  </view>

  <!-- Canvas -->
  <canvas type="2d" id="qrcodeCanvas" class="hidden-canvas" style="width: 260px; height: 260px;"></canvas>

  <!-- 错误提示 -->
  <view class="error-toast" wx:if="{{errorMsg}}">
    <text>{{errorMsg}}</text>
  </view>

  <!-- 生成历史 -->
  <view class="gen-history" wx:if="{{genHistory.length > 0}}">
    <view class="gen-history-header">
      <text class="gen-history-title">生成历史</text>
      <text class="gen-history-clear" bindtap="clearGenHistory">清空</text>
    </view>
    <view class="gen-history-list">
      <view class="gen-history-item" wx:for="{{genHistory}}" wx:key="time" bindtap="onHistoryItemTap" data-item="{{item}}">
        <view class="gen-history-left">
          <text class="gen-history-type qrcode">二维码</text>
          <text class="gen-history-text">{{item.text}}</text>
        </view>
        <text class="gen-history-time">{{item.time}}</text>
      </view>
    </view>
  </view>
</scroll-view>
