.page-container {
  height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 32rpx;
  box-sizing: border-box;
  max-width: 100vw;
  overflow-x: hidden;
}

/* 卡片 */
.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.card-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

/* 输入区域 */
.content-input {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  padding: 16rpx;
  background: #f5f6fa;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.char-count {
  text-align: right;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #bbb;
}

/* 配置区域 */
.config-row {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.config-row:last-child {
  border-bottom: none;
}

.config-label {
  font-size: 26rpx;
  color: #555;
  font-weight: 500;
  margin-bottom: 12rpx;
  display: block;
}

.config-hint {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

/* 选项按钮 */
.config-options {
  display: flex;
  gap: 16rpx;
}

.option-btn {
  width: 80rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  background: #f5f6fa;
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
  transition: all 0.2s;
}

.option-btn.active {
  background: #667eea;
  color: #fff;
  font-weight: 600;
}

/* 颜色选择 */
.color-picker {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.color-preview {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  border: 2rpx solid #e0e0e0;
  flex-shrink: 0;
}

.color-input {
  flex: 1;
  height: 64rpx;
  background: #f5f6fa;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  color: #333;
  font-family: 'Courier New', monospace;
}

/* 滑块 */
.config-slider {
  width: 100%;
  margin: 0;
}

/* 开关行 */
.switch-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.switch-row .config-label {
  margin-bottom: 0;
}

/* 生成按钮 */
.btn-generate {
  background: linear-gradient(135deg, #ff6b6b, #ee5a24);
  border-radius: 16rpx;
  padding: 28rpx 0;
  text-align: center;
  margin-bottom: 32rpx;
  margin-top: 0;
  box-shadow: 0 8rpx 24rpx rgba(238, 90, 36, 0.4);
}

.btn-generate text {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
}

.btn-generate:active {
  opacity: 0.85;
  transform: scale(0.98);
}

/* 预览区域 */
.preview-section {
  animation: fadeIn 0.4s ease;
  margin-bottom: 24rpx;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.preview-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.preview-image {
  width: 500rpx;
}

.preview-text {
  margin-top: 24rpx;
  padding: 12rpx 24rpx;
  background: #f5f6fa;
  border-radius: 8rpx;
  max-width: 100%;
  overflow: hidden;
}

.preview-text text {
  font-size: 24rpx;
  color: #666;
  word-break: break-all;
}

.preview-tip {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 16rpx;
}

.action-buttons {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
  margin-bottom: 0;
}

.btn-action {
  flex: 1;
  border-radius: 12rpx;
  padding: 20rpx 0;
  text-align: center;
}

.btn-action text {
  font-size: 26rpx;
  font-weight: 500;
}

.btn-save {
  background: #ffffff;
}

.btn-save text {
  color: #667eea;
}

.btn-share {
  background: #07c160;
}

.btn-share text {
  color: #ffffff;
}

.btn-copy {
  background: rgba(255, 255, 255, 0.2);
}

.btn-copy text {
  color: #ffffff;
}

.btn-action:active {
  opacity: 0.8;
}

/* 隐藏 Canvas */
.hidden-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
}

/* 错误提示 */
.error-toast {
  position: fixed;
  bottom: 120rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0, 0, 0, 0.75);
  color: #fff;
  padding: 20rpx 40rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  z-index: 999;
  animation: fadeIn 0.3s ease;
}

/* 生成历史 */
.gen-history {
  margin-top: 16rpx;
  margin-bottom: 40rpx;
}

.gen-history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.gen-history-title {
  font-size: 30rpx;
  color: #fff;
  font-weight: 600;
}

.gen-history-clear {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.gen-history-list {
  background: rgba(255, 255, 255, 0.12);
  border-radius: 16rpx;
  overflow: hidden;
}

.gen-history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
}

.gen-history-item:last-child {
  border-bottom: none;
}

.gen-history-left {
  flex: 1;
  overflow: hidden;
  margin-right: 16rpx;
  min-width: 0;
}

.gen-history-type {
  display: inline-block;
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  margin-bottom: 4rpx;
  color: #fff;
}

.gen-history-type.qrcode {
  background: rgba(102, 126, 234, 0.5);
}

.gen-history-text {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.gen-history-time {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
  flex-shrink: 0;
}
